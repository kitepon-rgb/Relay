# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# --- Server (single port serves both MCP and OAuth via path namespacing) ---
RELAY_PORT=18804

# Public URL of the MCP endpoint (used in OAuth resource metadata and as the JWT audience).
# Example: https://example.com/relay/mcp
RELAY_PUBLIC_MCP_URL=https://example.invalid/relay/mcp

# Public base URL of the OAuth authorization server (used as the OAuth issuer).
# Endpoints (/authorize, /token, /register, /consent) hang off this base.
# MUST share the origin with RELAY_PUBLIC_MCP_URL but use a different path.
# Example: https://example.com/relay/auth
RELAY_PUBLIC_AUTH_URL=https://example.invalid/relay/auth

# Random secret used to sign issued OAuth tokens.
# Generate with: openssl rand -base64 64
RELAY_OAUTH_SIGNING_KEY=change-me-to-a-long-random-string

# Passcode the operator must enter on the consent page when approving a
# new Connector. Anyone who knows this can register devices, so treat it
# like a password. Generate with: openssl rand -base64 18
RELAY_ADMIN_PASSCODE=change-me-to-something-only-you-know

# --- Storage ---
# Path to the SQLite database file (created on first run).
# In Docker, mount a volume here so data survives restarts.
RELAY_DB_PATH=./data/relay.db

# --- Misc ---
LOG_LEVEL=info
