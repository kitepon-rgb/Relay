# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# --- MCP resource server (the part that exposes /mcp) ---
RELAY_PORT=18804
# Public URL the MCP endpoint is reachable at (used in OAuth metadata).
# Example: https://relay.example.invalid/mcp
RELAY_PUBLIC_URL=https://relay.example.invalid/mcp

# --- OAuth authorization server ---
RELAY_AUTH_PORT=18805
# Public URL the auth server is reachable at.
# Example: https://relay.example.invalid/auth
RELAY_AUTH_PUBLIC_URL=https://relay.example.invalid/auth

# Random secret used to sign issued OAuth tokens.
# Generate with: openssl rand -base64 64
RELAY_OAUTH_SIGNING_KEY=change-me-to-a-long-random-string

# --- Storage ---
# Path to the SQLite database file (created on first run).
# In Docker, mount a volume here so data survives restarts.
RELAY_DB_PATH=./data/relay.db

# --- Misc ---
LOG_LEVEL=info
