# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# --- Server ---
# Single internal port serves both MCP and OAuth. The reverse proxy in
# front (Caddy / nginx / Traefik) terminates TLS and forwards to this port.
RELAY_PORT=18804

# Public URL of the MCP endpoint. Used in OAuth resource metadata and as the
# JWT audience claim. Must be reachable from the Claude clients (iPhone, PC).
#
# Subdomain layout (recommended — clean root paths):
#   RELAY_PUBLIC_MCP_URL=https://relay.example.com/mcp
#
# Path layout (when sharing a hostname with another MCP):
#   RELAY_PUBLIC_MCP_URL=https://example.com/relay/mcp
RELAY_PUBLIC_MCP_URL=https://relay.example.invalid/mcp

# Public base URL of the OAuth authorization server. Endpoints (/authorize,
# /token, /register, /consent) hang off this base. MUST share the origin
# with RELAY_PUBLIC_MCP_URL but use a different path.
#
# Subdomain layout:
#   RELAY_PUBLIC_AUTH_URL=https://relay.example.com
#
# Path layout:
#   RELAY_PUBLIC_AUTH_URL=https://example.com/relay/auth
RELAY_PUBLIC_AUTH_URL=https://relay.example.invalid

# Random secret used to sign JWT access tokens (HS256). Must be at least
# 32 characters. Generate with: openssl rand -base64 64
RELAY_OAUTH_SIGNING_KEY=change-me-to-a-long-random-string

# Passcode the operator must enter on the consent page when approving a
# new Connector. Anyone who knows this can register devices, so treat it
# like a password. Minimum 8 characters.
# Generate with: openssl rand -base64 18
RELAY_ADMIN_PASSCODE=change-me-to-something-only-you-know

# --- Storage ---
# Path to the SQLite database file (created on first run). It will hold
# entries, registered OAuth clients, authorization codes (60s TTL), and
# refresh-token hashes (90d TTL).
# In Docker, mount a volume here so data survives restarts.
RELAY_DB_PATH=./data/relay.db

# --- Misc ---
# debug | info | warn | error
LOG_LEVEL=info
